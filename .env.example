# 이 파일은 커밋 가능. 실제 값은 .env (gitignore 대상)에 입력.
# cp .env.example .env  후 값 채우기.

# ========== 필수 ==========

# Claude API 키 (https://console.anthropic.com/ 에서 발급)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# 세션 서명 시크릿 (최소 32자 랜덤값, openssl rand -hex 32 로 생성)
SESSION_SECRET=change-me-to-random-32-bytes-hex-string

# ========== 선택 ==========

# DB (회원제 도입 시)
# DATABASE_URL=postgresql://user:password@localhost:5432/sajuweb

# Redis (세션 스토어용, 서버 메모리 사용 시 불요)
# REDIS_URL=redis://localhost:6379

# 에러 모니터링 (선택)
# SENTRY_DSN=https://...@sentry.io/...

# ========== 런타임 설정 ==========

# 실행 환경: development | staging | production
NODE_ENV=development

# 서버 포트
PORT=3000

# 허용 Origin (CORS) - 콤마 구분
ALLOWED_ORIGINS=http://localhost:3000

# Rate limit (분당 채팅 호출 상한)
RATE_LIMIT_CHAT_PER_MINUTE=10

# 세션 TTL (초)
SESSION_TTL_SECONDS=86400
